{
  "name": "image-gen-mcp",
  "version": "1.0.0",
  "description": "MCP server for multi-provider image generation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "check-models": "tsx scripts/check-models.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:runs": "vitest run tests/runs"
  },
  "keywords": [
    "mcp",
    "image-generation",
    "claude",
    "openai",
    "gemini",
    "replicate",
    "grok"
  ],
  "author": "Ben Lamm",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.2.1",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^12.2.0",
    "openai": "^4.0.0",
    "replicate": "^1.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
